{
    "name": "upmind/provision-provider-generic",
    "description": "This provision category contains common functions which should cover the lifecycle of the majority of provisionable online services. Ships with a custom function definition which can be used for additional flexibility.",
    "type": "library",
    "require": {
        "upmind/provision-provider-base": "^3.7 || ^4.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^9.6 || ^10.5 || ^11.0 || ^12.0",
        "psy/psysh": "^0.12.22"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Upmind\\ProvisionProviders\\Generic\\LaravelServiceProvider"
            ]
        }
    },
    "license": "GPL-3.0-only",
    "autoload": {
        "psr-4": {
            "Upmind\\ProvisionProviders\\Generic\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Harry Lewis",
            "email": "harry@upmind.com"
        }
    ],
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
